# test_output scratch (prefixed with _ = internal scratch, not for commit)
# Per cleanup 2026-07-16: 50+ `_*.log/.txt/.py` files in test_output/ are
# debug scratch / commit message drafts. Kept on disk, not tracked.
test_output/_*.log
test_output/_*.txt
test_output/_*.sqlite
# Note: test_output/_test_*.py and test_output/_demo_* are kept; they're
# the actual e2e tests and sample output.
# Note: test_output/_debug_*.py/.html are NOT auto-ignored (some are
# useful artifacts). Add specific patterns if they grow.

# Per 2026-07-22 cleanup: system_outputs backup dirs and snapshot dirs are
# historical checkpoints (consume ~50MB). Kept on disk, not tracked.
# Naming: anything matching these patterns is a pre-rebuild backup.
bench/v01/system_outputs_combined.*/
bench/v01/system_outputs_combined_v3_9_*/
bench/v01/system_outputs_v3_9_*/
# Per 2026-07-22 cleanup: old v4-combined format files in system_outputs/
# (no .json extension; superseded by q001.json, q002.json, etc.)
bench/v01/system_outputs/q0[!j]*
bench/v01/system_outputs/q[1-9]*
bench/v01/system_outputs/q[1-9][0-9]*

