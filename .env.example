# API keys for paper-agent
# Copy this file to .env and fill in your actual keys.
# .env is gitignored; never commit real keys.

# CORE.ac.uk API (https://core.ac.uk/services/api)
# Free tier: register at https://core.ac.uk/services/api
# Format: 32-char alphanumeric string
CORE_API_KEY=your_core_api_key_here

# Semantic Scholar API (https://www.semanticscholar.org/product/api)
# Free tier: 1 RPS without key, 100 RPS with key
# Format: starts with "s2k-" followed by 30+ chars
S2_API_KEY=your_s2_api_key_here

# OpenAlex API (https://openalex.org/api)
# Free tier: no key needed for low volume
# With key: higher rate limits + premium features
# Format: 32-char alphanumeric string
OPENALEX_API_KEY=your_openalex_api_key_here

# Unpaywall API (https://unpaywall.org/products/api)
# Free tier: requires verified email
# Format: standard email address
UNPAYWALL_EMAIL=your_verified_email@example.com
